# These variables must also be set in your Vercel project settings
# (Project → Settings → Environment Variables) for production builds.
# Copy this file to .env.local and fill in real values — never commit .env.local.

# Your deployed domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://portfoliio-gold.vercel.app

# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=usman.data002@gmail.com

# Sender address shown in the email — must use a domain you have verified in Resend
# See: https://resend.com/docs/dashboard/domains/introduction
CONTACT_FROM_EMAIL=Contact Form <contact@your-domain.com>
